@startuml TouristaStudio_UC_QLDonDatPhong
!theme plain

title QUẢN LÝ ĐƠN ĐẶT PHÒNG

rectangle "Hệ thống Tourista" {

    actor "Khách hàng" as KH #blue
    actor "Quản trị viên" as QTV #red

    (Tìm kiếm phòng) as UC1
    (Xem chi tiết phòng) as UC2
    (Đặt phòng) as UC3
    (Hủy đặt phòng) as UC4
    (Xác nhận đặt phòng) as UC5
    (Xem danh sách đặt phòng) as UC6
    (Cập nhật trạng thái) as UC7
    (Xem thông tin thanh toán) as UC8
    (Xuất hóa đơn) as UC9

    KH -up-> UC1
    KH -up-> UC2
    KH -up-> UC3
    KH -up-> UC4
    KH -up-> UC8

    QTV -down-> UC5
    QTV -down-> UC6
    QTV -down-> UC7
    QTV -down-> UC9
}

@enduml
