@startuml TouristaStudio_UseCase_Customer
!theme plain
scale 1.0

title BIỂU ĐỒ USE CASE — SUBSYSTEM KHÁCH HÀNG

' ============================================================
' ACTORS
' ============================================================
actor "Khách (Guest)" as GUEST
actor "Khách hàng (Customer)" as CUSTOMER
actor "AI Chatbot (Gemini)" as AI
actor "VNPay" as VNPAY
actor "Hệ thống Email" as EMAIL

' ============================================================
' SUBSYSTEM CUSTOMER
' ============================================================
rectangle "Subsystem Khách hàng" {

    ' --- Nhóm Xác thực ---
    package "Xác thực & Tài khoản" {
        usecase "UC01\nĐăng ký tài khoản" as UC01
        usecase "UC02\nĐăng nhập (JWT)" as UC02
        usecase "UC03\nĐăng nhập OAuth2\n(Google / Facebook)" as UC03
        usecase "UC04\nXác thực email" as UC04
        usecase "UC05\nQuên mật khẩu /\nĐặt lại mật khẩu" as UC05
        usecase "UC06\nĐăng xuất" as UC06
        usecase "UC07\nXem hồ sơ cá nhân" as UC07
        usecase "UC08\nChỉnh sửa hồ sơ\n(thông tin, avatar)" as UC08
        usecase "UC09\nĐổi mật khẩu" as UC09
    }

    ' --- Nhóm Khách sạn ---
    package "Tìm kiếm & Đặt phòng" {
        usecase "UC10\nXem trang chủ\n& slideshow ảnh" as UC10
        usecase "UC11\nTìm kiếm khách sạn\n(theo thành phố, ngày,\nsố người, mức giá)" as UC11
        usecase "UC12\nBộ lọc & Sắp xếp\nkết quả tìm kiếm" as UC12
        usecase "UC13\nXem chi tiết khách sạn\n(phòng, tiện nghi, đánh giá,\nbản đồ, FAQ, tour gần đó)" as UC13
        usecase "UC14\nXem lịch giá\n(Price Calendar)" as UC14
        usecase "UC15\nChọn loại phòng\n& xem ưu đãi" as UC15
        usecase "UC16\nĐặt phòng khách sạn\n(điền thông tin, chọn ngày,\nchọn phòng)" as UC16
        usecase "UC17\nXác nhận đặt phòng" as UC17
    }

    ' --- Nhóm Tour ---
    package "Tour Du lịch" {
        usecase "UC20\nTìm kiếm tour\n(theo điểm đến, ngày,\nsố người, danh mục)" as UC20
        usecase "UC21\nXem chi tiết tour\n(lịch trình, ngày khởi hành,\nslot còn trống)" as UC21
        usecase "UC22\nĐặt tour du lịch" as UC22
        usecase "UC23\nXem lịch khởi hành\n(Tour Departure Calendar)" as UC23
    }

    ' --- Nhóm Combo ---
    package "Gói Combo" {
        usecase "UC25\nXem danh sách Combo\n(khách sạn + tour,\nưu đãi tiết kiệm)" as UC25
        usecase "UC26\nXem chi tiết Combo\n(phòng đã chọn + tour)" as UC26
        usecase "UC27\nĐặt Combo\n(đặt đồng thời\nkhách sạn + tour)" as UC27
    }

    ' --- Nhóm Thanh toán ---
    package "Thanh toán" {
        usecase "UC30\nChọn phương thức\nthanh toán" as UC30
        usecase "UC31\nThanh toán qua VNPay\n(ATM, QR, Visa)" as UC31
        usecase "UC32\nNhận thông báo\nthanh toán thành công\n(IPN Callback)" as UC32
        usecase "UC33\nHủy thanh toán /\nĐặt lại" as UC33
    }

    ' --- Nhóm Đặt chỗ ---
    package "Quản lý Đặt chỗ" {
        usecase "UC35\nXem lịch sử đặt phòng\n/ tour / combo" as UC35
        usecase "UC36\nXem chi tiết đơn đặt\n(trạng thái, thông tin,\nmã đặt chỗ)" as UC36
        usecase "UC37\nHủy đặt phòng / tour\n(kèm lý do)" as UC37
        usecase "UC38\nXem mã QR đặt chỗ" as UC38
        usecase "UC39\nNhận thông báo\nqua Email / Push" as UC39
    }

    ' --- Nhóm Đánh giá ---
    package "Đánh giá & Phản hồi" {
        usecase "UC40\nViết đánh giá\n(khách sạn / tour,\nđiểm + bình luận + ảnh/video)" as UC40
        usecase "UC41\nXem đánh giá\n& phản hồi từ đối tác" as UC41
        usecase "UC42\nĐánh dấu hữu ích\ncho đánh giá" as UC42
        usecase "UC43\nSửa / xóa đánh giá\ncủa mình" as UC43
    }

    ' --- Nhóm Yêu thích ---
    package "Yêu thích" {
        usecase "UC45\nLưu khách sạn / tour\nvào danh sách yêu thích" as UC45
        usecase "UC46\nXem danh sách\nyêu thích" as UC46
        usecase "UC47\nBỏ lưu khỏi\nyêu thích" as UC47
    }

    ' --- Nhóm Khuyến mãi ---
    package "Khuyến mãi" {
        usecase "UC50\nXem danh sách\nkhuyến mãi đang có" as UC50
        usecase "UC51\nXem chi tiết mã\ngiảm giá" as UC51
        usecase "UC52\nÁp dụng mã\nkhuyến mãi khi đặt" as UC52
    }

    ' --- Nhóm AI ---
    package "AI Thông minh" {
        usecase "UC55\nChat với AI Chatbot\n(tra cứu booking,\nFAQ, gợi ý điểm đến)" as UC55
        usecase "UC56\nAI Travel Planner\n(nhập ngân sách, số người,\nngày đi → tạo lịch trình\ndu lịch cá nhân hóa)" as UC56
        usecase "UC57\nXem lịch trình\nAI đã tạo" as UC57
        usecase "UC58\nĐặt luôn từ\nlịch trình AI" as UC58
    }

    ' --- Nhóm Chat ---
    package "Chat Real-time" {
        usecase "UC60\nChat với chủ khách sạn\n/ đối tác (P2P)" as UC60
        usecase "UC61\nNhận tin nhắn\nreal-time (WebSocket)" as UC61
        usecase "UC62\nXem lịch sử cuộc trò chuyện" as UC62
    }

    ' --- Nhóm Tin tức ---
    package "Cẩm nang Du lịch" {
        usecase "UC65\nXem danh sách bài viết\n(cẩm nang du lịch, tin tức)" as UC65
        usecase "UC66\nXem chi tiết bài viết\n(bài blog, hướng dẫn)" as UC66
    }
}

