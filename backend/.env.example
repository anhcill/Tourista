# ============================================================
# Tourista Backend — Environment Variables Template
# ============================================================
# Sao chép file này thành .env và điền giá trị thực tế.
# KHÔNG commit .env vào git!

# ===== DATABASE =====
MYSQLHOST=localhost
MYSQLPORT=3306
MYSQLDATABASE=tourista
MYSQLUSER=root
MYSQLPASSWORD=

# ===== JWT =====
# Sinh secret bằng: openssl rand -base64 64
JWT_SECRET=

# ===== GOOGLE OAUTH2 =====
# Lấy từ Google Cloud Console → APIs & Services → Credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ===== EMAIL SMTP =====
# Dùng App Password (không phải mật khẩu Gmail thường)
# Tạo tại: Google Account → Security → 2-Step Verification → App passwords
MAIL_USERNAME=
MAIL_PASSWORD=

# ===== FRONTEND =====
FRONTEND_URL=http://localhost:3000

# ===== CORS =====
APP_CORS_ALLOWED_ORIGINS=http://localhost:3000,https://tourista-nine.vercel.app

# ===== VNPAY =====
# Lấy từ https://sandbox.vnpayment.vn/
VNPAY_TMN_CODE=
VNPAY_HASH_SECRET=
VNPAY_PAY_URL=https://sandbox.vnpayment.vn/paymentv2/vpcpay.html
VNPAY_RETURN_URL=http://localhost:3000/payments/vnpay/return

# ===== GEMINI AI =====
# Lấy từ https://aistudio.google.com/
GEMINI_API_KEY=
