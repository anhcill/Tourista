# Backend environment template for local/staging/prod
# Copy to .env (or set equivalent system/env variables) before running.

# ===== DATABASE =====
# Option 1 (recommended): set DB_* explicitly
DB_URL=jdbc:mysql://localhost:3306/tourista?useSSL=false&serverTimezone=Asia/Ho_Chi_Minh&allowPublicKeyRetrieval=true
DB_USERNAME=root
DB_PASSWORD=change_me

# Option 2 (Railway variables): app can read MYSQLHOST/MYSQLPORT/MYSQLDATABASE/MYSQLUSER/MYSQLPASSWORD directly.
# Example with your Railway host:
# DB_URL=jdbc:mysql://maglev.proxy.rlwy.net:44405/railway?useSSL=false&serverTimezone=Asia/Ho_Chi_Minh&allowPublicKeyRetrieval=true
# DB_USERNAME=root
# DB_PASSWORD=<railway_mysql_password>

# ===== JWT =====
# Must be at least 32 bytes for HS256.
JWT_SECRET=replace_with_long_random_secret_min_32_bytes

# ===== MAIL (SMTP) =====
# Gmail App Password: dùng mật khẩu ứng dụng 16 ký tự (nên bỏ khoảng trắng khi paste).
# Ví dụ hiển thị: abcd efgh ijkl mnop -> dùng: abcdefghijklmnop
MAIL_USERNAME=
MAIL_PASSWORD=

# ===== OAUTH2 =====
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
FRONTEND_URL=http://localhost:3000
APP_CORS_ALLOWED_ORIGINS=http://localhost:3000

# ===== VNPAY =====
VNPAY_TMN_CODE=
VNPAY_HASH_SECRET=
VNPAY_PAY_URL=https://sandbox.vnpayment.vn/paymentv2/vpcpay.html
VNPAY_RETURN_URL=http://localhost:3000/payments/vnpay/return

# ===== GEMINI =====
GEMINI_API_KEY=
