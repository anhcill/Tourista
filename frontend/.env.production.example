# ============================================================
# Tourista Frontend — Production Environment Template
# ============================================================
# Sao chép thành .env.production và điền giá trị thực tế.
# Đặt biến này TRƯỚC khi build Docker image.
#
# Trên Railway (khuyến nghị - dùng build args):
#   Đặt biến NEXT_PUBLIC_API_URL trong phần Variables của service.
#
#   Ví dụ Railway backend URL: https://tourista-production.up.railway.app/api
#   Dùng: --build-arg NEXT_PUBLIC_API_URL=https://tourista-production.up.railway.app/api
#
# Cách hoạt động:
#   - Railway chạy backend trên port 8080 trong cùng container
#   - Frontend gọi API đến NEXT_PUBLIC_API_URL
#   - CORS backend phải allow origin của frontend

NEXT_PUBLIC_API_URL=http://localhost:8080/api
